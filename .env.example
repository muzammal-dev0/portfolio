# Optional: canonical site URL for Open Graph (e.g. https://yoursite.com)
# VITE_SITE_URL=

# Server-only chatbot vars (do NOT prefix with VITE_)
# Copy to `.env` for local dev with `vercel dev`
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Pushover — https://pushover.net/
# PUSHOVER_APP_TOKEN = API token from your Pushover application
# PUSHOVER_USER_KEY = your user key from the Pushover dashboard
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Optional rate limit for /api/chat (requests per IP per minute)
CHAT_RATE_LIMIT_PER_MIN=10
